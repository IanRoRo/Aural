import pygetwindow as gw
import time
import csv
from datetime import datetime
from pynput import mouse, keyboard

class AuralMonitor:
    def __init__(self):
        self.last_input_time = time.time()
        # Configurem els "espies" de teclat i ratolí (Pas 1.3)
        self.mouse_listener = mouse.Listener(on_move=self._reset_timer, on_click=self._reset_timer, on_scroll=self._reset_timer)
        self.kb_listener = keyboard.Listener(on_press=self._reset_timer)
        self.mouse_listener.start()
        self.kb_listener.start()

    def _reset_timer(self, *args):
        self.last_input_time = time.time()

    def get_data(self):
        # Pas 1.2
        try:
            win = gw.getActiveWindow()
            title = win.title if win else "Escriptori"
        except:
            title = "Desconegut"
        
        # Pas 1.3: Considerem inactiu si passen més de 120 segons (2 min)
        actiu = "SI" if (time.time() - self.last_input_time) < 120 else "NO"
        
        # Data i hora actual
        ara = datetime.now()
        return [ara.strftime("%Y-%m-%d"), ara.strftime("%H:%M:%S"), title, actiu]

# --- EXECUCIÓ (Pas 1.1 i 1.4) ---
monitor = AuralMonitor()
file_name = "registre_activitat.csv"

print("Aural està registrant dades... No facis el vago.")

try:
    while True:
        dades = monitor.get_data()
        
        # Guardar en CSV (Pas 1.4)
        with open(file_name, mode='a', newline='', encoding='utf-16') as f:
            writer = csv.writer(f)
            writer.writerow(dades)
        
        print(f"Registrat: {dades[2]} | Actiu: {dades[3]}")
        
        time.sleep(5) # El bucle de 5 segons
except KeyboardInterrupt:
    print("\nAural s'ha cansat de vigilar-te. Adéu.")
